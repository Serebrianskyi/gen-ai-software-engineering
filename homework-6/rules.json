{
  "validation": {
    "required_fields": [
      "transaction_id", "timestamp", "source_account",
      "destination_account", "amount", "currency", "transaction_type"
    ],
    "approved_currencies": ["USD", "EUR", "GBP", "JPY", "CHF", "CAD", "AUD", "SGD", "HKD", "NOK", "SEK", "DKK"],
    "amount_must_be_positive": true
  },
  "fraud": {
    "flag_threshold": 0.4,
    "rules": [
      {"id": "high_value",   "description": "Amount > $10,000",                    "score": 0.4},
      {"id": "structuring",  "description": "Amount between $9,000 and $9,999.99", "score": 0.3},
      {"id": "off_hours",    "description": "UTC hour is 22, 23, or 0 through 5",  "score": 0.3},
      {"id": "cross_border", "description": "metadata.country is not 'US'",        "score": 0.2}
    ]
  }
}
