{
  "validation": {
    "required_fields": [
      "transaction_id", "timestamp", "source_account",
      "destination_account", "amount", "currency", "transaction_type"
    ],
    "approved_currencies": ["USD", "EUR", "GBP"],
    "amount_must_be_positive": true
  },
  "fraud": {
    "flag_threshold": 0.2,
    "rules": [
      {"id": "high_value",   "description": "Amount > $5,000",                     "score": 0.4},
      {"id": "structuring",  "description": "Amount between $4,500 and $4,999.99", "score": 0.3},
      {"id": "off_hours",    "description": "UTC hour is 20, 21, 22, 23, or 0-6",  "score": 0.3},
      {"id": "cross_border", "description": "metadata.country is not 'US'",        "score": 0.2}
    ]
  }
}
